# ─── Timón · Variables de entorno ───────────────────────────────────────
# Copia este archivo como .env y rellena los valores.
# Las variables con prefijo TIMON_ las lee el backend (FastAPI).
# Las variables con prefijo NEXT_PUBLIC_ las lee el frontend (Next.js).

# ── Google OAuth (Google Cloud Console) ──
# 1. Ve a https://console.cloud.google.com/apis/credentials
# 2. Crea un "ID de cliente OAuth 2.0" de tipo "Aplicación web"
# 3. Agrega en "Orígenes autorizados de JavaScript": http://localhost:3000
# 4. Agrega en "URIs de redireccionamiento autorizados": http://localhost:3000
# 5. Copia el Client ID y Client Secret aquí:
TIMON_GOOGLE_CLIENT_ID=
TIMON_GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# IMPORTANTE: TIMON_GOOGLE_CLIENT_ID y NEXT_PUBLIC_GOOGLE_CLIENT_ID
# deben tener el MISMO valor (el Client ID de Google).

# ── JWT ──
# Cambia esto a un secreto fuerte en producción (usa: openssl rand -hex 32)
TIMON_JWT_SECRET=change-me-in-production
TIMON_JWT_ALGORITHM=HS256
TIMON_JWT_EXPIRE_MINUTES=1440
